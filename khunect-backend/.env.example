# ─────────────────────────────────────────
# KHU-nect 백엔드 환경변수 템플릿
# 이 파일을 .env 로 복사한 뒤 실제 값을 채워넣으세요
# cp .env.example .env
# ─────────────────────────────────────────

# Spring 프로파일 (로컬: local, 서버: dev)
SPRING_PROFILES_ACTIVE=dev

# DB 설정
DB_NAME=khunect
DB_USERNAME=khunect
DB_PASSWORD=your-strong-db-password

# JWT 설정 (32자 이상 랜덤 문자열)
JWT_SECRET=your-very-long-random-secret-key-here-minimum-32-chars

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 배포 도메인으로 변경 (예: https://api.yourdomain.com)
GOOGLE_REDIRECT_URI=https://your-domain.com/login/oauth2/code/google

# Vercel 프론트엔드 주소
FRONTEND_BASE_URL=https://your-app.vercel.app

# 인증 콜백 경로
AUTH_CALLBACK_PATH=/auth/callback

# 허용 이메일 도메인
ALLOWED_EMAIL_DOMAIN=khu.ac.kr
